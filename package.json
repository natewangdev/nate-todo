{
  "name": "nate-todo",
  "version": "0.1.1",
  "description": "Windows 侧边悬浮球待办",
  "author": "NateTodo",
  "engines": {
    "node": ">=18.0.0"
  },
  "main": "./out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
    "build:app": "electron-vite build",
    "preview": "electron-vite preview"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.10.0",
    "electron": "^35.0.0",
    "electron-builder": "^26.8.1",
    "electron-vite": "^5.0.0",
    "typescript": "^5.9.0",
    "vite": "^6.3.0"
  },
  "build": {
    "appId": "com.nate.todo",
    "productName": "NateTodo",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "portable": {
      "artifactName": "${productName}-${version}-portable.exe"
    }
  }
}
